Date: Sat, 14 Mar 2026 06:16:53 +0000
Subject: [PATCH 18/21] riscv64: dts: sophgo: enable uart4 for
 sg2000-milkv-duo-s bluetooth

---
 arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
index 713154e75e21..d320b5c4ad5c 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
@@ -83,6 +83,10 @@ &uart0 {
 	status = "okay";
 };
 
+&uart4 {
+	status = "okay";
+};
+
 &usb {
 	dr_mode = "otg";
 	status = "okay";
